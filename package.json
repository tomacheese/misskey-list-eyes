{
  "name": "misskey-list-eyes",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "output/index.js",
  "repository": "https://github.com/tomacheese/misskey-list-eyes",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register ./src/main.ts",
    "dev": "ts-node-dev --poll -r tsconfig-paths/register ./src/main.ts",
    "package": "run-s clean compile packing",
    "packing": "ncc build ./dist/main.js -o output/",
    "compile": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist output",
    "lint": "run-p -c lint:prettier lint:eslint lint:tsc",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "test": "jest",
    "fix": "run-s fix:prettier fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@book000/node-utils": "1.24.250",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "@vercel/ncc": "0.44.0",
    "eslint": "10.5.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "prettier": "3.9.0",
    "puppeteer-core": "25.2.1",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "6.0.3",
    "yarn-run-all": "3.1.1"
  }
}
